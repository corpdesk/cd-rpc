{
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "Node",
    "target": "ES2020",

    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,

    "esModuleInterop": true,
    "resolveJsonModule": true,

    "sourceMap": true,
    "strict": false,

    "skipLibCheck": true,

    "outDir": "dist",
    "rootDir": "."
  }
}