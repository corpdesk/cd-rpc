{
  "compilerOptions": {
    "module": "CommonJS",
    "esModuleInterop": true,
    "target": "es2019",
    "moduleResolution": "Node",

    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,

    "sourceMap": true,

    "outDir": "dist",
    "rootDir": ".",

    "resolveJsonModule": true,

    "skipLibCheck": true,

    "strict": false
  },

  "include": ["src/**/*"],

  "exclude": [
    "node_modules",
    "dist"
  ]
}